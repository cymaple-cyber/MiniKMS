# Copy this file to .env before running MiniKMS locally or with Docker.
#
# Generate strong values:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

DATABASE_URL=sqlite:///./data/minikms.db
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60
MASTER_KEY=replace-with-base64-encoded-32-byte-master-key

